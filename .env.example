# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key (safe to expose in the app bundle)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Price ID for the $25.99/month subscription plan
EXPO_PUBLIC_STRIPE_PRICE_ID=price_...

# ── Supabase Edge Function secrets ────────────────────────────────────────────
# Set these via: supabase secrets set KEY=value
# (Never put these in .env — they run server-side only)
#
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
