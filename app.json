{
  "expo": {
    "name": "Loom",
    "slug": "loom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "loom",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.loom.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Loom uses your location to show you compatible people nearby.",
        "NSPhotoLibraryUsageDescription": "Loom uses your photo library so you can add photos to your profile.",
        "NSCameraUsageDescription": "Loom uses your camera so you can take a profile photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.loom.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Loom uses your photo library so you can add photos to your profile.",
          "cameraPermission": "Loom uses your camera so you can take a profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Loom uses your location to show you compatible people nearby."
        }
      ],
      "@stripe/stripe-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
